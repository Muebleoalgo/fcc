---
import { SITE } from 'astrowind:config';
---

<span class="self-center ml-2 rtl:ml-0 rtl:mr-2 flex items-center">
  <img src="/images/logo-fcc.png" alt={SITE?.name || 'FCC'} class="h-12 w-auto logo-white" />
  <img src="/images/logo-fcc-color.png" alt={SITE?.name || 'FCC'} class="h-12 w-auto logo-color" />
</span>

<style is:global>
  /* POR DEFECTO (Móvil): El fondo es blanco, así que mostramos el logo a color */
  .logo-white { display: none; }
  .logo-color { display: block; }

  /* MODO OSCURO (Móvil y Desktop): Forzamos siempre el logo blanco */
  html.dark .logo-white { display: block !important; }
  html.dark .logo-color { display: none !important; }

  /* DESKTOP (Pantallas medianas y grandes) */
  @media (min-width: 768px) {
    /* Estado inicial (Header transparente sobre foto oscura): Logo blanco */
    html:not(.dark) #header:not(.scroll) .logo-white {
      display: block;
    }
    html:not(.dark) #header:not(.scroll) .logo-color {
      display: none;
    }
    
    /* Al hacer scroll (Fondo se vuelve blanco): Logo a color */
    html:not(.dark) #header.scroll .logo-white {
      display: none;
    }
    html:not(.dark) #header.scroll .logo-color {
      display: block;
    }
  }

  /* REGLA NUEVA PARA HEADER PAGINAS BLANCAS (light) */
  /* Solo aplica en ESCRITORIO si el header tiene la clase 'header-light' y NO hay scroll */
  @media (min-width: 768px) {
    html:not(.dark) #header.header-light:not(.scroll):not(.expanded) .header-menu-list > li > a,
    html:not(.dark) #header.header-light:not(.scroll):not(.expanded) .theme-toggle-container button {
      color: var(--aw-color-text-default) !important; /* Restaurar color oscuro */
    }
    
    /* Y forzamos el logo a color */
    html:not(.dark) #header.header-light:not(.scroll) .logo-white { display: none !important; }
    html:not(.dark) #header.header-light:not(.scroll) .logo-color { display: block !important; }
  }
</style>