---
import Layout from '~/layouts/PageLayout.astro';

import Hero from '~/components/widgets/Hero.astro';
import Note from '~/components/widgets/Note.astro';
import Features from '~/components/widgets/Features.astro';
import Content from '~/components/widgets/Content.astro';
import FAQs from '~/components/widgets/FAQs.astro';
import Stats from '~/components/widgets/Stats.astro';
import CallToAction from '~/components/widgets/CallToAction.astro';

const metadata = {
  title: 'Fundación Comunitaria Cajamarca | Conectando nuestra región',
  ignoreTitleTemplate: true,
};

// Rutas actualizadas para apuntar a la carpeta public/ y evitar que se rompan en producción
const carouselImagesIndex = [
  '/images/proyecto1.webp',
  '/images/proyecto2.webp',
  '/images/proyecto3.webp'
];
---

<Layout metadata={metadata}>
  
  <Hero
    actions={[
      {
        variant: 'primary',
        text: 'Haz una donación',
        href: '/donaciones/donaciones',
        target: '_self',
        icon: 'tabler:heart',
      },
      { text: 'Conoce nuestro impacto', href: '#impacto' },
    ]}
    carouselImages={carouselImagesIndex}
  >
    <Fragment slot="title">
      Fundación Comunitaria Cajamarca
      <span class="text-accent dark:text-white block text-4xl md:text-5xl mt-2"
        >Conectando a los cajamarquinos</span
      >
    </Fragment>

    <Fragment slot="subtitle">
      Canalizamos recursos y articulamos alianzas para impulsar proyectos en educación, salud y desarrollo que transforman vidas en nuestra región.
    </Fragment>
  </Hero>

  <Stats
    id="impacto"
    title="Nuestro impacto en números"
    subtitle="La transparencia y los resultados son nuestra mejor carta de presentación."
    stats={[
      { title: 'Proyectos Articulados', amount: 2 },
      { title: 'Soles Movilizados', amount: 5000 },
      { title: 'Vidas Impactadas', amount: 300 },
      { title: 'Aliados Estratégicos', amount: 10 },
    ]}
  />

  <Note />

  <Features
    id="metodologia"
    tagline="Nuestra Metodología"
    title="Puentes para el desarrollo"
    subtitle="Trabajamos codo a codo con la sociedad civil y el sector privado para garantizar que la ayuda llegue donde más se necesita."
    items={[
      {
        title: 'Articulación',
        description: 'Gestamos alianzas locales e internacionales para multiplicar el impacto de cada iniciativa.',
        icon: 'tabler:users',
      },
      {
        title: 'Transparencia',
        description: 'Trazabilidad total de los fondos. Procesos claros para mantener la confianza de nuestros donantes.',
        icon: 'tabler:shield-check',
      },
      {
        title: 'Sostenibilidad',
        description: 'No hacemos asistencialismo; impulsamos proyectos con visión a largo plazo y respeto al entorno.',
        icon: 'tabler:leaf',
      },
      {
        title: 'Acción Comunitaria',
        description: 'Escuchamos primero. Actuamos en base a las necesidades reales diagnosticadas por la propia comunidad.',
        icon: 'tabler:user-plus',
      },
    ]}
  />

  <Content
    isReversed
    tagline="Casos de Éxito"
    title="El esfuerzo en acción"
    items={[
      {
        title: 'Maratón por los Sueños',
        description: 'Movilización deportiva comunitaria que logró financiar mejoras cruciales para la Escuela Jesús Trabajador.',
        icon: 'tabler:run',
      },
      {
        title: 'Fortalecimiento Institucional',
        description: 'Talleres estratégicos para potenciar la gestión y sostenibilidad de diversas organizaciones civiles cajamarquinas.',
        icon: 'tabler:building-community',
      },
    ]}
    image={{
      src: '/images/proyectos-fcc.webp', // Actualizado a la carpeta public
      alt: 'Voluntarios de la Fundación Comunitaria Cajamarca en acción',
    }}
  />

  <CallToAction
    actions={[
      {
        variant: 'primary',
        text: 'Dona ahora',
        href: '/donaciones/donaciones',
        target: '_self',
        icon: 'tabler:gift',
      },
      {
        text: 'Sé voluntario',
        href: '/voluntarios/voluntarios',
        icon: 'tabler:hand-stop',
      },
    ]}
  >
    <Fragment slot="title"> El cambio empieza aquí </Fragment>
    <Fragment slot="subtitle">
      Tu aporte, ya sea en tiempo o recursos, es el motor que mantiene viva nuestra labor en Cajamarca. ¿Te sumas?
    </Fragment>
  </CallToAction>

  <FAQs
    title="Preguntas Frecuentes"
    subtitle="Todo lo que necesitas saber para empezar a colaborar."
    tagline="Transparencia"
    classes={{ container: 'max-w-5xl' }}
    items={[
      {
        title: '¿Qué es un fondo comunitario?',
        description: 'Es un "pozo" de recursos financieros construido por múltiples donantes, administrado rigurosamente por la FCC para financiar proyectos locales a largo plazo.',
      },
      {
        title: '¿A dónde va mi donación?',
        description: 'El 100% de tu donación puede ir a un proyecto específico de tu elección, o al fondo general para atender las necesidades más urgentes de la región.',
      },
      {
        title: '¿Cómo me uno a la red de voluntarios?',
        description: 'Solo debes completar el formulario en nuestra sección de Voluntarios. Nuestro equipo te contactará para invitarte a la próxima inducción.',
      },
      {
        title: '¿Puedo presentar un proyecto para financiamiento?',
        description: 'Sí. Constantemente evaluamos propuestas de la sociedad civil. Contáctanos a través del formulario principal para enviarte las bases de postulación.',
      },
    ]}
  />
</Layout>