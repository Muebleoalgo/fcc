---
import Layout from '~/layouts/PageLayout.astro';

import Hero from '~/components/widgets/Hero.astro';
import Steps from '~/components/widgets/Steps.astro';
import Features2 from '~/components/widgets/Features2.astro';
import Stats from '~/components/widgets/Stats.astro';
import FAQs from '~/components/widgets/FAQs.astro';

//import { YouTube } from 'astro-embed'; --- toca importar video

const metadata = {
  title: 'Historia de la FCC',
};
---

<Layout metadata={metadata}>
  <!-- Hero Widget ******************* -->

  <Hero
    tagline="Nuestra Historia"
    image={{
      src: '/images/proyecto1.webp',
      alt: 'Trabajo comunitario en Cajamarca',
    }}
  >
<Fragment slot="title">
  Creación y Desarrollo de la <span class="highlight"
    >Fundación Comunitaria Cajamarca</span
  >
</Fragment>

    <Fragment slot="subtitle">
      La Fundación Comunitaria Cajamarca nace de la necesidad de promover prácticas sostenibles y el desarrollo
      comunitario en Cajamarca, Perú
    </Fragment>
  </Hero>

  <!-- Timeline Widget ************** -->

  <Steps
  title="Nuestra Cronología: El Camino de la FCC"
  items={[
    {
      title: '2022:',
      description: 'Inicio del Proyecto',
      /*description:
        'Damos nuestros primeros pasos. Participamos con entusiasmo en la convocatoria del programa "Incubadora Territorial 2da Edición". Fuimos seleccionados gracias al compromiso y la motivación palpable por mejorar la calidad de vida en nuestra región.',*/
      icon: 'tabler:bulb', // Icono de la semilla
    },
    {
      title: '2023-2024:',
      description: 'Capacitación y Planificación',
      /*description:
        'Iniciamos un proceso intensivo de formación especializada en Fundaciones Territoriales. Desarrollamos el plan de trabajo estratégico que sentaría las bases operativas e institucionales de la futura FCC.',*/
      icon: 'tabler:books', // Icono de estudio/libros
    },
    {
      title: '16 de Julio de 2024:',
      description: 'Constitución Legal Institucional',
      /*description:
        'Un hito fundamental. Logramos la constitución legal de la FCC como persona jurídica bajo la razón social "FT Cajamarca", dándonos la formalidad necesaria para actuar.',*/
      icon: 'tabler:certificate', // Icono de certificado/legal
    },
    {
      title: 'Septiembre de 2024:',
      description: 'I Maratón por los Sueños',
     /*description:
        'Lanzamos nuestra primera gran iniciativa. Logramos la articulación exitosa de instituciones educativas y donantes en la "Maratón por los sueños" para apoyar a niños en situación de vulnerabilidad.',*/
      icon: 'tabler:star', // Icono de logro/estrella
    },
    {
      title: 'Marzo de 2025:',
      description: 'I Alianza e Intercambio Internacional',
     /*description:
        'Lanzamos nuestra primera gran iniciativa. Logramos la articulación exitosa de instituciones educativas y donantes en la "Maratón por los sueños" para apoyar a niños en situación de vulnerabilidad.',*/
      icon: 'tabler:star', // Icono de logro/estrella
    },
    {
      title: 'Noviembre de 2025:',
      description: 'Resolución de Exoneración del Impuesto a la Renta',
     /*description:
        'Lanzamos nuestra primera gran iniciativa. Logramos la articulación exitosa de instituciones educativas y donantes en la "Maratón por los sueños" para apoyar a niños en situación de vulnerabilidad.',*/
      icon: 'tabler:certificate', // Icono de logro/estrella
    },
    {
      title: 'Febrero de 2026:',
      description: 'Resolución que nos faculta como Ente Perceptor de Donaciones',
     /*description:
        'Lanzamos nuestra primera gran iniciativa. Logramos la articulación exitosa de instituciones educativas y donantes en la "Maratón por los sueños" para apoyar a niños en situación de vulnerabilidad.',*/
      icon: 'tabler:certificate', // Icono de logro/estrella
    },
    {
      title: 'Presente',
      description: 'Seguimos trabajando por el desarrollo de Cajamarca',
     /*description:
        'Lanzamos nuestra primera gran iniciativa. Logramos la articulación exitosa de instituciones educativas y donantes en la "Maratón por los sueños" para apoyar a niños en situación de vulnerabilidad.',*/
      icon: 'tabler:star', // Icono de logro/estrella
    },
  ]}
/>

  <!-- Features2 Widget ************** -->

  <Features2
    title="Acerca de Nosotros"
    subtitle="La FCC fue fundada en el año 2024 como resultado de una colaboración entre individuos comprometidos con la mejora de la comunidad en Cajamarca."
  >
    <Fragment slot="bg">
      <div class="absolute inset-0 bg-blue-50 dark:bg-transparent"></div>
    </Fragment>
  </Features2>

  <!-- Stats Widget ****************** -->

  <Stats
    title="Logros de la FCC"
    subtitle="Estas cifras reflejan nuestro compromiso con el desarrollo de Cajamarca y el impacto positivo que hemos logrado."
    stats={[
      { title: 'Años de trabajo', amount: '2' },
      { title: 'Comunidades impactadas', amount: '2' },
      { title: 'Personas beneficiadas', amount: '300' },
      { title: 'Talleres y Eventos organizados', amount: '5' },
    ]}
  />

 

  <Fragment slot="bg">
      <div class="absolute inset-0 bg-blue-50 dark:bg-transparent"></div>
    </Fragment>


  <!-- FAQs Widget ******************* -->

  <FAQs
  title="Preguntas Frecuentes"
  items={[
    {
      title: '¿Qué es la Fundación Comunitaria Cajamarca?',
      description:
        'Es una organización dedicada a impulsar el desarrollo de nuestra región. Actuamos como un puente estratégico que conecta voluntades y recursos para potenciar el impacto social en la comunidad.',
    },
    {
      title: '¿Cómo puedo participar en los proyectos?',
      description:
        'Puedes sumarte como donante, aliado estratégico o voluntario. Escríbenos a través de nuestros canales oficiales o redes sociales para descubrir cómo tu aporte puede transformar vidas.',
    },
    {
      title: '¿Qué actividades realiza la FCC?',
      description:
        'Como organización de la sociedad civil, nos dedicamos a fortalecer a otras organizaciones, articulando redes de donantes y gestionando recursos para respaldar iniciativas solidarias.',
    },
    {
      title: '¿Dónde están ubicadas sus oficinas?',
      description:
        'Nuestra sede central se encuentra en la ciudad de Cajamarca, desde donde coordinamos todas las alianzas y el apoyo para las diversas organizaciones de la región.',
    },
  ]}
>
    <Fragment slot="bg">
      <div class="absolute inset-0 bg-blue-50 dark:bg-transparent"></div>
    </Fragment>
  </FAQs>

  <!-- Features3 Widget ************** -->

   <!-- CallToAction Widget *********** -->

</Layout>
