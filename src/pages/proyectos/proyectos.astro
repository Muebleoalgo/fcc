---
import Layout from '~/layouts/PageLayout.astro';

import Header from '~/components/widgets/Header.astro';
import Hero2 from '~/components/widgets/Hero2.astro';
import Content from '~/components/widgets/Content.astro';

import { headerData } from '~/navigation';
import FAQs from '~/components/widgets/FAQs.astro';

const metadata = {
  title: 'FCC: Proyectos de la Fundación Comunitaria Cajamarca',
};
---

<Layout metadata={metadata} headerTheme="light">
  <Fragment slot="header">
    <Header
      {...headerData}
      actions={[
        {
          variant: 'secondary',
          text: 'Login',
          href: '#',
        },
        {
          variant: 'primary',
          text: 'Sign Up',
          href: '#',
        },
      ]}
      isSticky={true}
      headerTheme="light"
    />
  </Fragment>

  <Hero2
    tagline="Impacto en Cajamarca"
    image={{
      src: 'https://images.unsplash.com/photo-1526948128573-703ee1aeb6fa?ixlib=rb-4.0.3&auto=format&fit=crop&w=2070&q=80',
      alt: 'Imagen de Proyectos FCC',
    }}
  >
    <Fragment slot="title">
      Comprometidos con el desarrollo de Cajamarca: <br /> nuestros <span class="text-accent dark:text-white highlight"
        >proyectos</span
      > estratégicos<br />
    </Fragment>

    <Fragment slot="subtitle">
      <span class="hidden sm:inline">
        Trabajamos como puente para articular recursos y transformar la realidad de nuestra región.</span
      >
      Desde la educación hasta la innovación económica, cada iniciativa cuenta.
    </Fragment>
  </Hero2>

