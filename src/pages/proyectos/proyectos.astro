  <Content
    isAfterContent={true}
    title="Maratón por los sueños"
    subtitle="El evento que moviliza a Cajamarca por la educación."
    items={[
      {
        title: 'Descripción:',
        description:
          'Un hito de articulación comunitaria que recauda fondos para la Escuela Jesús Trabajador. Es nuestro principal motor de visibilidad y captación de recursos para causas educativas urgentes.',
      },
      {
        title: 'Impacto:',
        description: `Articula a donantes, deportistas y empresas en una sola causa. <br /> Provee recursos directos para equipamiento y nutrición en los escolares. <br /> Sensibiliza a la población sobre las brechas educativas.`,
      },
    ]}
    image={{
      src: 'https://images.unsplash.com/photo-1461896756913-6d9ee99bc11c?ixlib=rb-4.0.3&auto=format&fit=crop&w=1671&q=80',
      alt: 'Maratón por los sueños',
    }}
  >
    <Fragment slot="content">
      <h3 class="text-2xl font-bold tracking-tight dark:text-white sm:text-3xl mb-2">
        Movilización Social: <br /><span class="text-2xl">Corriendo por el futuro</span>
      </h3>
    </Fragment>
  </Content>

  <Content
    isReversed={true}
    isAfterContent={true}
    title="Sostenibilidad y Fortalecimiento Civil"
    subtitle="Cuidando el entorno y profesionalizando a nuestras organizaciones."
    items={[
      {
        title: 'Reforestación:',
        description: `Proyectos de recuperación de suelos y áreas verdes en colaboración con comunidades y organizaciones locales para combatir el cambio climático.`,
      },
      {
        title: 'Capacitación OSC:',
        description: `Talleres de gestión, sostenibilidad y articulación para que otras Organizaciones de la Sociedad Civil multipliquen su impacto.`,
      },
    ]}
    image={{
      src: 'https://images.unsplash.com/photo-1542601906990-b4d3fb778b09?ixlib=rb-4.0.3&auto=format&fit=crop&w=1658&q=80',
      alt: 'Sostenibilidad',
    }}
  >
    <Fragment slot="content">
      <h3 class="text-2xl font-bold tracking-tight dark:text-white sm:text-3xl mb-2">
        Más allá del hoy: <br /><span class="text-2xl">Compromiso a largo plazo</span>
      </h3>
    </Fragment>
    <Fragment slot="bg">
      <div class="absolute inset-0 bg-blue-50 dark:bg-transparent"></div>
    </Fragment>
  </Content>

  <FAQs
    title="Preguntas Frecuentes"
    items={[
      {
        title: '¿Cómo puedo apoyar estos proyectos?',
        description:
          'Gracias a nuestra reciente calificación como Ente Perceptor de Donaciones, puedes realizar aportes económicos con beneficios fiscales o sumarte como aliado estratégico en la ejecución técnica.',
        icon: 'tabler:chevrons-right',
      },
      {
        title: '¿Cuál es el impacto total de la FCC?',
        description: `Hemos impactado directamente en áreas de educación y desarrollo comunitario en Cajamarca, trabajando con instituciones como la Escuela Jesús Trabajador y diversas comunidades rurales.`,
        icon: 'tabler:chevrons-right',
      },
      {
        title: '¿Son una organización ejecutora?',
        description:
          'Somos una Fundación Comunitaria (de segundo nivel), lo que significa que articulamos recursos y conocimientos para que los proyectos sean sostenibles, trabajando de la mano con líderes y organizaciones locales.',
        icon: 'tabler:chevrons-right',
      },
    ]}
  >
    <Fragment slot="bg">
      <div class="absolute inset-0 bg-blue-50 dark:bg-transparent"></div>
    </Fragment>
  </FAQs>
</Layout>