---
import Layout from '~/layouts/PageLayout.astro';
import Hero from '~/components/widgets/Hero.astro';
import VolunteerForm from '~/components/widgets/VolunteerForm.astro';
import Testimonials from '~/components/widgets/Testimonials.astro'; // Importamos el widget oficial

const metadata = {
  title: 'Únete como Voluntario | FCC',
  ignoreTitleTemplate: true,
};
---

<Layout metadata={metadata}>
  <Hero
    image={{
      src: '/images/nosotros2.webp',
      alt: 'Trabajo comunitario en Cajamarca',
      // FUNDAMENTAL: La capa oscura para que el menú principal blanco se lea perfecto
      class: 'absolute inset-0 object-cover w-full h-full opacity-40', 
    }}
  >
    <Fragment slot="content">
      <div class="flex flex-col lg:flex-row justify-between items-stretch gap-8 mt-4 md:mt-12">

        <div class="w-full lg:w-1/2 bg-white/90 dark:bg-slate-900/80 backdrop-blur-md p-8 md:p-10 rounded-2xl shadow-2xl text-left border border-gray-200 dark:border-gray-700">
          <h1 class="text-3xl md:text-5xl font-bold leading-tight text-primary dark:text-white mb-4">
            Sé el cambio que deseas ver en el mundo
          </h1>
          <p class="text-xl font-medium text-slate-600 dark:text-slate-300 italic mb-8">
            - Mahatma Gandhi
          </p>

          <h2 class="font-bold text-xl mb-6 text-slate-800 dark:text-white">Beneficios de unirte a nuestra red:</h2>
          
          <ul class="space-y-4">
            <li class="flex items-start">
              <span class="text-primary mr-3 text-xl">✔</span>
              <span class="text-slate-700 dark:text-slate-300 font-medium">Certificación oficial por horas de voluntariado.</span>
            </li>
            <li class="flex items-start">
              <span class="text-primary mr-3 text-xl">✔</span>
              <span class="text-slate-700 dark:text-slate-300 font-medium">Desarrollo de liderazgo y gestión de proyectos.</span>
            </li>
            <li class="flex items-start">
              <span class="text-primary mr-3 text-xl">✔</span>
              <span class="text-slate-700 dark:text-slate-300 font-medium">Impacto directo y real en el desarrollo de Cajamarca.</span>
            </li>
            <li class="flex items-start">
              <span class="text-primary mr-3 text-xl">✔</span>
              <span class="text-slate-700 dark:text-slate-300 font-medium">Networking con profesionales y líderes locales.</span>
            </li>
          </ul>
        </div>

        <div class="w-full lg:w-1/2 bg-white/90 dark:bg-slate-900/80 backdrop-blur-md p-8 md:p-10 rounded-2xl shadow-2xl border border-gray-200 dark:border-gray-700 flex flex-col justify-center">
          <VolunteerForm 
            title='<span class="leading-tight text-primary dark:text-white mb-4 block text-3xl md:text-4xl">Únete como Voluntario</span>'
            subtitle="Sé parte activa del cambio"
            tagline="Completa tus datos y nuestro equipo se pondrá en contacto contigo."
          />
        </div>

      </div>
    </Fragment>
  </Hero>

  <Testimonials
    title="Historias de nuestros voluntarios"
    subtitle="Descubre la experiencia de quienes ya están transformando nuestra región."
    testimonials={[
      {
        testimonial: 'Ser voluntaria en la FCC me permitió crecer como persona, aplicar lo que aprendo en la universidad y contribuir directamente a mi comunidad. Es una experiencia que te cambia la perspectiva por completo.',
        name: 'María López',
        job: 'Voluntaria - Maratón por los Sueños',
        image: {
          src: 'https://images.unsplash.com/photo-1438761681033-6461ffad8d80?ixlib=rb-4.0.3&auto=format&fit=crop&w=2070&q=80',
          alt: 'Foto referencial de voluntaria',
        },
      },
      // Puedes agregar más objetos de testimonios aquí
    ]}
  />
</Layout>